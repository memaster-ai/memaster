{
  "name": "memaster",
  "version": "0.1.0",
  "description": "TypeScript client for the Memaster cloud memory API",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "files": ["index.js", "index.cjs", "index.d.ts", "README.md"],
  "scripts": {
    "test": "node --test test/client.test.mjs"
  },
  "keywords": ["memaster", "memory", "ai", "sdk", "client"],
  "author": "Memaster",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/memaster-ai/memaster.git",
    "directory": "typescript"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
