# Memaster Memory Skill configuration
#
# Copy this file to `.env.local` in the same directory and replace the
# placeholder values. `.env.local` is ignored by git and must never be
# committed because it contains your real API key.

# Memaster API endpoint.
# Keep the default for Memaster Cloud. Use your private deployment URL for
# enterprise/self-hosted installations.
MEMASTER_BASE_URL=https://api.memaster.cn

# Required. Create it in Dashboard → API Keys.
# The value below is a placeholder; replace it with your real `m0sk_xxx` key.
MEMASTER_API_KEY=m0sk_xxx

# Recommended. Stable end-user or developer identity used to scope memories.
# Changing this value switches to another memory namespace.
MEMASTER_USER_ID=your-user-id

# Optional but recommended. Identifies the assistant/editor/agent using memory,
# such as `claude-code`, `cursor`, `windsurf`, `devin`, or `openclaw`.
MEMASTER_AGENT_ID=your-agent-id

# Optional. Written to metadata.source so memories can be filtered by origin.
MEMASTER_SOURCE=your-editor

# Optional. Written to metadata.service. Usually keep this as `Memaster`.
MEMASTER_SERVICE=Memaster

# Recommended. Project/repository/product name used for filtering and metadata.
# `add` and `update` require project/area either from env or CLI arguments.
MEMASTER_PROJECT=your-project

# Recommended. Module, package, or documentation area, for example:
# `server-golang/docs`, `dashboard/pricing`, or `skills/memaster-memory`.
MEMASTER_AREA=your-area

# Optional. Feature/topic scope, for example `auth-login`, `docs-navigation`,
# `ai-editor-integrations`, or `pricing-payment`.
MEMASTER_SCOPE=your-scope

# Optional. Set true to let `add` send infer=true so the server extracts
# durable memories from the input instead of storing the whole text verbatim.
MEMASTER_INFER=false

# Optional. Increase this when MEMASTER_INFER=true because LLM extraction may
# take longer than regular add/search/list requests.
MEMASTER_TIMEOUT_SECONDS=20

# Optional. Default number of results returned by search.
MEMASTER_TOP_K=5
