{
  "name": "@memaster-ai/openclaw-memaster",
  "version": "0.1.2",
  "description": "Memaster long-term memory backend for OpenClaw agents",
  "license": "Apache-2.0",
  "keywords": [
    "openclaw",
    "plugin",
    "memory",
    "memaster",
    "long-term-memory"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "openclaw-memaster": "dist/init-cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./init-cli": {
      "types": "./dist/init-cli.d.ts",
      "import": "./dist/init-cli.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.47"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memaster-ai/memaster-clients.git",
    "directory": "integrations/openclaw-memaster"
  },
  "homepage": "https://docs.memaster.cn/integrations/openclaw",
  "publishConfig": {
    "access": "public"
  }
}
